COMPOSE_PROJECT_NAME=n8n
# External task runners do not publish a stable tag. Pin a version that exists
# for both docker.n8n.io/n8nio/n8n and n8nio/runners.
N8N_IMAGE_TAG=1.121.0

# Public URL settings. Put n8n behind HTTPS with Nginx, Caddy, Traefik, or a load balancer.
N8N_HOST=n8n.example.com
N8N_PROTOCOL=https
N8N_PORT=3001
N8N_BIND_ADDRESS=127.0.0.1
WEBHOOK_URL=https://n8n.example.com/
N8N_EDITOR_BASE_URL=https://n8n.example.com/
N8N_PROXY_HOPS=1
N8N_SECURE_COOKIE=true

GENERIC_TIMEZONE=Asia/Yangon
TZ=Asia/Yangon

# Host safety checks. Increase these for heavier workflow loads.
MIN_CPU_CORES=4
MIN_MEMORY_MB=8192
MIN_FREE_DISK_MB=51200
MIN_BACKUP_FREE_DISK_MB=102400

# Container resource caps for an 8 CPU / 32 GB SOC queue-mode install.
POSTGRES_CPUS=1.5
POSTGRES_MEMORY=8g
REDIS_CPUS=0.5
REDIS_MEMORY=2g
N8N_MAIN_CPUS=1.5
N8N_MAIN_MEMORY=4g
N8N_WORKER_CPUS=2.0
N8N_WORKER_MEMORY=6g
N8N_RUNNERS_CPUS=0.5
N8N_RUNNERS_MEMORY=1g
POSTGRES_SHARED_BUFFERS=2GB
POSTGRES_WORK_MEM=32MB
POSTGRES_MAINTENANCE_WORK_MEM=512MB
POSTGRES_MAX_CONNECTIONS=200
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3

# Replace these before first start. Do not change N8N_ENCRYPTION_KEY after credentials exist.
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me-generate-a-long-password
N8N_ENCRYPTION_KEY=change-me-generate-a-32-plus-character-key
N8N_RUNNERS_AUTH_TOKEN=change-me-generate-a-long-runner-token
REDIS_PASSWORD=change-me-generate-a-long-redis-password

# Queue mode and execution controls.
EXECUTIONS_MODE=queue
OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true
N8N_WORKER_CONCURRENCY=5
N8N_CONCURRENCY_PRODUCTION_LIMIT=20
QUEUE_BULL_REDIS_DB=0
QUEUE_BULL_REDIS_TIMEOUT_THRESHOLD=10000
QUEUE_HEALTH_CHECK_ACTIVE=true
N8N_GRACEFUL_SHUTDOWN_TIMEOUT=60
N8N_DEFAULT_BINARY_DATA_MODE=database
N8N_EVENTBUS_LOGWRITER_MAXTOTALMESSAGESPERFILE=500000

# Execution cleanup keeps the database from growing forever.
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=336

# Keep unattended image updates disabled until you have tested restore for this host.
N8N_AUTO_UPDATE=false
N8N_UPDATE_AUTO_ROLLBACK=true
N8N_ROLLBACK_HEALTH_ATTEMPTS=30
N8N_ROLLBACK_IMAGE_RETENTION_DAYS=14
N8N_SECURITY_UPDATE_OVERRIDE=false
N8N_UPDATE_LOG_ERROR_SCAN=true
N8N_UPDATE_SECURITY_ADVISORY_CHECK=true

# Backup retention and optional encrypted offsite upload.
# Set RCLONE_REMOTE to a configured rclone remote, preferably a crypt remote.
BACKUP_RETENTION_DAYS=14
RCLONE_REMOTE=
RCLONE_TRANSFERS=4
RCLONE_CHECKERS=8

# Monitoring thresholds used by scripts/monitor.sh.
MONITOR_MIN_FREE_DISK_MB=51200
MONITOR_BACKUP_MAX_AGE_HOURS=26
MONITOR_UPDATE_LOG_MAX_AGE_HOURS=26

# Privacy and update notifications.
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=true
